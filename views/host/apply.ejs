<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <div class="col-8 offset-2">
        <h3>Become a Host</h3>

        <form action="/host/apply" method="POST" novalidate class="needs-validation" enctype="multipart/form-data">

            <div class="mb-3">
                <label for="businessName" class="form-label">Business Name</label>
                <input
                    type="text"
                    name="host[name]"
                    id="businessName"
                    placeholder="Enter Business Name"
                    class="form-control"
                    required
                >
                <div class="invalid-feedback">Please enter a Business Name</div>
            </div>

            <div class="mb-3">
                <label for="businessAddress" class="form-label">Business Address</label>
                <textarea
                    name="host[address]"
                    id="businessAddress"
                    rows="3"
                    placeholder="Enter Business Address"
                    class="form-control"
                    required
                ></textarea>
                <div class="invalid-feedback">Please enter a Business Address</div>
            </div>

            <!-- ✅ License field — outside other divs, properly placed -->
            <div class="mb-3">
                <label for="license" class="form-label">Business License</label>
                <input
                    type="file"
                    name="license"
                    id="license"
                    accept="image/*,.pdf"
                    class="form-control"
                    required
                />
                <div class="invalid-feedback">Please upload your business license</div>
            </div>

            <button class="btn btn-dark mt-3">Submit</button>

        </form>
        <br>
    </div>
</div>